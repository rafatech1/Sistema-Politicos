# ---- Banco (Postgres no Railway) ----
# Copie a "Connection URL" do serviço Postgres no painel do Railway.
DATABASE_URL="postgresql://user:password@host.railway.internal:5432/railway"

# ---- Autenticação (JWT com refresh token, senhas com bcrypt) ----
# Nome tem que ser JWT_ACCESS_SECRET — é o que src/lib/auth/jwt.ts e src/lib/env.ts leem.
JWT_ACCESS_SECRET="troque-por-uma-string-aleatoria-forte"
JWT_REFRESH_SECRET="troque-por-outra-string-aleatoria-forte"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- App ----
NODE_ENV="development"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Upload de mídia (disco local por padrão; S3-compat opcional: R2 / Backblaze) ----
# Grava sempre em public/uploads (ver src/lib/media/local-storage-adapter.ts) — sem variável de path.
# Ao usar MEDIA_STORAGE_PROVIDER="s3", todas as variáveis S3_* abaixo passam a
# ser obrigatórias (validado em src/lib/env.ts, falha no boot se faltar alguma).
# MEDIA_STORAGE_PROVIDER="local"        # local | s3
# S3_ENDPOINT=""
# S3_REGION="auto"
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_PUBLIC_BASE_URL=""
