# ------------------------------------------------------------------
# Configuração de DEPLOY (por cliente). Nunca commitar o .env real.
# Copie este arquivo para .env e preencha os valores da instância.
# ------------------------------------------------------------------

# Banco de dados (uma instância Postgres dedicada por candidato)
DATABASE_URL="postgresql://user:password@localhost:5432/sistema_politicos?schema=public"

# Segredos JWT — gerados automaticamente pelo `npm run setup` se ausentes.
# Se preencher manualmente, use valores aleatórios longos (ex: openssl rand -hex 64).
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# URL pública do site (usada em metadata, sitemap, links absolutos)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Upload de mídia: "local" (dev) ou "s3" (produção, S3-compatível: R2/Backblaze)
MEDIA_STORAGE_PROVIDER="local"
# Preenchidos apenas quando MEDIA_STORAGE_PROVIDER=s3
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# Ambiente
NODE_ENV="development"
